<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>arke</AssemblyName>
    <RootNamespace>Arke.Cli</RootNamespace>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- Package as a .NET tool: `dotnet tool install` puts `arke` on PATH (SPEC-017 open question). -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>arke</ToolCommandName>
  </PropertyGroup>

  <ItemGroup>
    <!-- Rich console rendering + the Cli command framework (split into its own package). -->
    <PackageReference Include="Spectre.Console" Version="0.55.0" />
    <PackageReference Include="Spectre.Console.Cli" Version="0.55.0" />
  </ItemGroup>

</Project>
