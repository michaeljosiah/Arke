{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/orchestrator/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|agent|model|gate|children|style|key|ref|className|style|children)$/]",
        "message": "<AgentMessage> doesn't accept that prop. Declared props: role, agent, model, gate, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentMessage'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:agent|human)$/]",
        "message": "<AgentMessage> role must be one of 'agent' | 'human'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|kind|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, kind, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:agent|human)$/]",
        "message": "<Avatar> kind must be one of 'agent' | 'human'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|outline|destructive)$/]",
        "message": "<Badge> variant must be one of 'default' | 'secondary' | 'outline' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|draft|review|approved|merged|teal|signal|ok|warn)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'draft' | 'review' | 'approved' | 'merged' | 'teal' | 'signal' | 'ok' | 'warn'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|iconLeft|iconRight|type|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, iconLeft, iconRight, type, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|outline|ghost|destructive|link)$/]",
        "message": "<Button> variant must be one of 'default' | 'secondary' | 'outline' | 'ghost' | 'destructive' | 'link'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|default|lg|icon)$/]",
        "message": "<Button> size must be one of 'sm' | 'default' | 'lg' | 'icon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|children|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: variant, label, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|destructive|success|warning|truth|signal|info|warn|ok)$/]",
        "message": "<Callout> variant must be one of 'default' | 'destructive' | 'success' | 'warning' | 'truth' | 'signal' | 'info' | 'warn' | 'ok'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padding|elevated|header|footer|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padding, elevated, header, footer, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|recessed|boundary|dark)$/]",
        "message": "<Card> variant must be one of 'default' | 'recessed' | 'boundary' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|variant|disabled|label|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, variant, disabled, label, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|default|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'default' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|outline|secondary)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'outline' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|type|disabled|invalid|mono|prefix|size|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, defaultValue, placeholder, type, disabled, invalid, mono, prefix, size, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|default|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'default' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KanbanCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:taskId|title|status|harness|model|needsHuman|style|key|ref|className|style|children)$/]",
        "message": "<KanbanCard> doesn't accept that prop. Declared props: taskId, title, status, harness, model, needsHuman, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KanbanCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:running|agree|ok|done|idle|waiting)$/]",
        "message": "<KanbanCard> status must be one of 'running' | 'agree' | 'ok' | 'done' | 'idle' | 'waiting'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:specId|title|status|meta|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<SpecCard> doesn't accept that prop. Declared props: specId, title, status, meta, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:draft|in-review|approved|merged)$/]",
        "message": "<SpecCard> status must be one of 'draft' | 'in-review' | 'approved' | 'merged'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|pulse|label|style|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, size, pulse, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:running|agree|ok|diverge|attention|waiting|idle|done)$/]",
        "message": "<StatusDot> status must be one of 'running' | 'agree' | 'ok' | 'diverge' | 'attention' | 'waiting' | 'idle' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|disabled|onChange|label|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, disabled, onChange, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|count|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|rows|disabled|mono|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: value, defaultValue, placeholder, rows, disabled, mono, onChange, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
